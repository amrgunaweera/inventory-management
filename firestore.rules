rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // ─── Default deny ──────────────────────────────────────────
    match /{document=**} {
      allow read, write: if false;
    }

    // ═══════════════════════════════════════════════════════════
    // Helper Functions
    // ═══════════════════════════════════════════════════════════

    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(uid) {
      return isAuthenticated() && request.auth.uid == uid;
    }

    // Check if the current user is a member of the given organization
    function isOrgMember(orgId) {
      return isAuthenticated() && exists(/databases/$(database)/documents/organizations/$(orgId)/members/$(request.auth.uid));
    }

    // Check if current user is an admin of the given organization
    function isOrgAdmin(orgId) {
      return isAuthenticated() &&
             get(/databases/$(database)/documents/organizations/$(orgId)/members/$(request.auth.uid)).data.role == 'admin';
    }

    // ═══════════════════════════════════════════════════════════
    // users/{uid}  — User profile document
    // ═══════════════════════════════════════════════════════════
    match /users/{uid} {
      // Users can read/write their own profile
      allow read, write: if isOwner(uid);
    }

    // ═══════════════════════════════════════════════════════════
    // organizations/{orgId}  — Organization docs
    // ═══════════════════════════════════════════════════════════
    match /organizations/{orgId} {
      // Only members can read org data
      allow read: if isOrgMember(orgId);
      
      // Only admins can update the org data (like name, plan)
      allow update: if isOrgAdmin(orgId);

      // Any authenticated user can create an organization
      allow create: if isAuthenticated();

      // ─── members subcollection ────────────────────────────
      match /members/{memberUid} {
        // Members can see who else is in the org
        allow read: if isOrgMember(orgId);

        // A user can add themselves during organization creation or invitation acceptance
        // Also admins can update/delete members
        allow write: if isOwner(memberUid) || isOrgAdmin(orgId);
      }

      // ─── invitations subcollection ────────────────────────
      match /invitations/{inviteId} {
        // Anyone authenticated can read invites to find their own
        allow read: if isAuthenticated();
        
        // Members with team.manage rights can create invites (simplified to admin or member)
        allow create, delete: if isOrgMember(orgId);
        
        // Users can accept their own invites (update status)
        allow update: if isAuthenticated();
      }

      // ─── shared collections ───────────────────────────────
      // In production, we'd add granular role checks for writes.
      // For now, any organization member can access their org's data.

      match /products/{id} {
        allow read, write: if isOrgMember(orgId);
      }

      match /categories/{id} {
        allow read, write: if isOrgMember(orgId);
      }

      match /orders/{id} {
        allow read, write: if isOrgMember(orgId);
      }

      match /suppliers/{id} {
        allow read, write: if isOrgMember(orgId);
      }

      match /warehouses/{id} {
        allow read, write: if isOrgMember(orgId);
      }

      match /auditLog/{id} {
        allow read: if isOrgAdmin(orgId);
        allow create: if isOrgMember(orgId);
      }
    }
  }
}
