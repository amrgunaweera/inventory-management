rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // ─── Default deny ──────────────────────────────────────────
    match /{document=**} {
      allow read, write: if false;
    }

    // ═══════════════════════════════════════════════════════════
    // Helper Functions
    // ═══════════════════════════════════════════════════════════

    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(uid) {
      return isAuthenticated() && request.auth.uid == uid;
    }

    function isSuperAdmin() {
      return isAuthenticated() && (
        exists(/databases/$(database)/documents/platform_admins/$(request.auth.uid)) ||
        (exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
         get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'super_admin') ||
        request.auth.token.email == 'demo.superadmin@smartventory.com'
      );
    }

    // Check if the current user is a member of the given organization (or a super admin)
    function isOrgMember(orgId) {
      return isSuperAdmin() || (isAuthenticated() && exists(/databases/$(database)/documents/organizations/$(orgId)/members/$(request.auth.uid)));
    }

    // Check if current user is the owner of the given organization (or a super admin)
    function isStoreOwner(orgId) {
      return isSuperAdmin() || (isAuthenticated() &&
             get(/databases/$(database)/documents/organizations/$(orgId)/members/$(request.auth.uid)).data.role == 'store_owner');
    }

    // ═══════════════════════════════════════════════════════════
    // users/{uid}  — User profile document
    // ═══════════════════════════════════════════════════════════
    match /users/{uid} {
      // Users can read their own profile, Super Admin can read all
      allow read: if isOwner(uid) || isSuperAdmin();
      
      // Users can write their profile but cannot set role to super_admin unless they are super admin
      allow write: if isSuperAdmin() || 
                   (isOwner(uid) && 
                    (!request.resource.data.keys().hasAll(['role']) || 
                     request.resource.data.role != 'super_admin'));
    }

    // ═══════════════════════════════════════════════════════════
    // categories/{id}  — Global product categories
    // ═══════════════════════════════════════════════════════════
    match /categories/{id} {
      allow read: if isAuthenticated();
      allow write: if isSuperAdmin();
    }

    // ═══════════════════════════════════════════════════════════
    // organizations/{orgId}  — Organization docs
    // ═══════════════════════════════════════════════════════════
    match /organizations/{orgId} {
      // Only members can read org data
      allow read: if isOrgMember(orgId);
      
      // Only admins can update the org data (like name, plan)
      allow update: if isStoreOwner(orgId);

      // Any authenticated user can create an organization
      allow create: if isAuthenticated();

      // ─── members subcollection ────────────────────────────
      match /members/{memberUid} {
        // Members can see who else is in the org
        allow read: if isOrgMember(orgId);

        // A user can add themselves during organization creation or invitation acceptance
        // Also admins can update/delete members
        allow write: if isOwner(memberUid) || isStoreOwner(orgId);
      }

      // ─── invitations subcollection ────────────────────────
      match /invitations/{inviteId} {
        // Anyone authenticated can read invites to find their own
        allow read: if isAuthenticated();
        
        // Members with team.manage rights can create invites (simplified to admin or member)
        allow create, delete: if isOrgMember(orgId);
        
        // Users can accept their own invites (update status)
        allow update: if isAuthenticated();
      }

      // ─── shared collections ───────────────────────────────
      // In production, we'd add granular role checks for writes.
      // For now, any organization member can access their org's data.

      match /products/{id} {
        allow read, write: if isOrgMember(orgId);
      }

      match /categories/{id} {
        allow read, write: if isOrgMember(orgId);
      }

      match /orders/{id} {
        allow read, write: if isOrgMember(orgId);
      }

      match /suppliers/{id} {
        allow read, write: if isOrgMember(orgId);
      }

      match /warehouses/{id} {
        allow read, write: if isOrgMember(orgId);
      }

      match /auditLog/{id} {
        allow read: if isStoreOwner(orgId);
        allow create: if isOrgMember(orgId);
      }
    }
  }
}
